---
import Layout from '../../layouts/Layout.astro';
import PublicationItem from '../../components/PublicationItem.astro';
import { getCollection } from 'astro:content';

const allPublications = await getCollection('publications');
const publications = allPublications.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Get unique years for filtering
const years = [...new Set(publications.map((p) => p.data.date.getFullYear()))].sort((a, b) => b - a);

// Group publications by year
const publicationsByYear = years.map((year) => ({
  year,
  publications: publications.filter((p) => p.data.date.getFullYear() === year),
}));
---

<Layout title="Publications" description="Research publications from the Intelligent Agricultural Systems group">
  <div class="section">
    <div class="container-narrow">
      <h1 class="text-3xl font-bold text-hs-gray-900 mb-2">Publications</h1>
      <p class="text-hs-gray-700 mb-8">
        Browse our research publications including journal articles, conference papers, and more.
      </p>

      {publications.length === 0 ? (
        <p class="text-hs-gray-500 text-center py-12">
          No publications yet. Check back soon!
        </p>
      ) : (
        <>
          <!-- Filter controls -->
          <div class="mb-8 flex flex-wrap gap-4 items-center">
            <div>
              <label for="year-filter" class="sr-only">Filter by year</label>
              <select
                id="year-filter"
                class="bg-white border border-hs-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-hs-cyan"
              >
                <option value="">All years</option>
                {years.map((year) => (
                  <option value={year}>{year}</option>
                ))}
              </select>
            </div>

            <span class="text-sm text-hs-gray-500" id="publication-count">
              {publications.length} publication{publications.length !== 1 ? 's' : ''}
            </span>
          </div>

          <!-- Publications grouped by year -->
          <div id="publications-list">
            {publicationsByYear.map(({ year, publications: yearPubs }) => (
              <section class="mb-8 publication-year-group" data-year={year}>
                <h2 class="text-xl font-medium text-hs-gray-900 mb-4 sticky top-0 bg-white py-2">
                  {year}
                </h2>
                <div class="bg-white rounded-lg border border-hs-gray-300 p-6">
                  {yearPubs.map((pub) => (
                    <div class="publication-item" data-year={pub.data.date.getFullYear()}>
                      <PublicationItem
                        slug={pub.slug}
                        title={pub.data.title}
                        authors={pub.data.authors}
                        date={pub.data.date}
                        doi={pub.data.doi}
                        pdfUrl={pub.data.pdfUrl}
                        codeUrl={pub.data.codeUrl}
                      />
                    </div>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </>
      )}
    </div>
  </div>
</Layout>

<script>
  const yearFilter = document.getElementById('year-filter') as HTMLSelectElement;
  const typeFilter = document.getElementById('type-filter') as HTMLSelectElement;
  const publicationCount = document.getElementById('publication-count');
  const yearGroups = document.querySelectorAll('.publication-year-group');
  const publications = document.querySelectorAll('.publication-item');

  function filterPublications() {
    const selectedYear = yearFilter.value;
    const selectedType = typeFilter.value;
    let visibleCount = 0;

    publications.forEach((pub) => {
      const pubYear = pub.getAttribute('data-year');
      const pubType = pub.getAttribute('data-type');

      const matchesYear = !selectedYear || pubYear === selectedYear;
      const matchesType = !selectedType || pubType === selectedType;

      if (matchesYear && matchesType) {
        pub.classList.remove('hidden');
        visibleCount++;
      } else {
        pub.classList.add('hidden');
      }
    });

    // Hide year groups with no visible publications
    yearGroups.forEach((group) => {
      const groupYear = group.getAttribute('data-year');
      const visibleInGroup = group.querySelectorAll('.publication-item:not(.hidden)').length;

      if (selectedYear && groupYear !== selectedYear) {
        group.classList.add('hidden');
      } else if (visibleInGroup === 0) {
        group.classList.add('hidden');
      } else {
        group.classList.remove('hidden');
      }
    });

    if (publicationCount) {
      publicationCount.textContent = `${visibleCount} publication${visibleCount !== 1 ? 's' : ''}`;
    }
  }

  yearFilter?.addEventListener('change', filterPublications);
  typeFilter?.addEventListener('change', filterPublications);
</script>
