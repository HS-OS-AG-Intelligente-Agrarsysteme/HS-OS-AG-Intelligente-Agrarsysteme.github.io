---
import logo from "../assets/logos/HS-OS-Logo-Quer-ohne_Hintergrund-cmyk.svg";

const navItems = [
  { label: "Research Topics", href: "/topics" },
  { label: "Publications", href: "/publications" },
  { label: "Theses", href: "/theses" },
  { label: "Team", href: "https://www.hs-osnabrueck.de/agro-technicum/team/", external: true },
  { label: "Contact", href: "https://www.hs-osnabrueck.de/prof-dr-stefan-stiene/", external: true },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-hs-gray-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 hover:no-underline">
        <img
          src={logo.src}
          alt="HS Osnabrück"
          class="h-20 md:h-24 object-contain"
        />
        <!--
        <span class="hidden sm:block text-hs-gray-900 font-medium text-sm md:text-base">
          AG Intelligente Agrarsysteme
        </span>
        -->
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-sm font-medium transition-colors hover:no-underline",
                !item.external && currentPath.startsWith(item.href)
                  ? "text-hs-cyan"
                  : "text-hs-gray-700 hover:text-hs-cyan",
              ]}
              {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 text-hs-gray-700 hover:text-hs-cyan"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <nav
      id="mobile-menu"
      class="hidden md:hidden pb-4 border-t border-hs-gray-300"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "block py-2 text-sm font-medium hover:no-underline",
              !item.external && currentPath.startsWith(item.href)
                ? "text-hs-cyan"
                : "text-hs-gray-700 hover:text-hs-cyan",
            ]}
            {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById("mobile-menu-button");
  const menu = document.getElementById("mobile-menu");

  button?.addEventListener("click", () => {
    const isExpanded = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", (!isExpanded).toString());
    menu?.classList.toggle("hidden");
  });
</script>
