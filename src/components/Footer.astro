---
const currentYear = new Date().getFullYear();
---

<footer class="bg-hs-gray-700 border-t border-[#555555]">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <!-- Quick Links - Centered -->
    <div class="flex justify-center">
      <div>
        <h3 class="text-sm font-medium text-hs-gray-100 mb-3 text-center">Quick Links</h3>
        <ul class="space-y-2 text-sm text-center">
          <li>
            <a href="/topics" class="text-[#e4e4e4] hover:text-hs-cyan"
              >Research Topics</a
            >
          </li>
          <li>
            <a href="/publications" class="text-[#e4e4e4] hover:text-hs-cyan"
              >Publications</a
            >
          </li>
          <li>
            <a href="/theses" class="text-[#e4e4e4] hover:text-hs-cyan"
              >Theses</a
            >
          </li>
          <li>
            <a
              href="https://www.hs-osnabrueck.de/agro-technicum/team/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#e4e4e4] hover:text-hs-cyan"
              >Team</a
            >
          </li>
          <li>
            <a
              href="https://www.hs-osnabrueck.de/prof-dr-stefan-stiene/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#e4e4e4] hover:text-hs-cyan"
              >Contact</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-8 pt-6 border-t border-[#555555] text-center text-sm text-[#e4e4e4]"
    >
      <p class="mb-2">
        &copy; {currentYear} AG Intelligente Agrarsysteme, University of Applied Sciences
        Osnabrück
      </p>
      <p class="space-x-4">
        <a href="/impressum" class="text-[#e4e4e4] hover:text-hs-cyan">
          Impressum
        </a>
        <span class="text-[#555555]">|</span>
        <a href="/datenschutz" class="text-[#e4e4e4] hover:text-hs-cyan">
          Datenschutzerklärung
        </a>
      </p>
    </div>
  </div>
</footer>
