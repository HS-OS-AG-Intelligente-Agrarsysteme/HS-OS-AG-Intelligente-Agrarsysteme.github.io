---
import { getImage } from 'astro:assets';

interface Slide {
  title: string;
  description: string;
  href: string;
  contentType: 'topic' | 'publication' | 'thesis';
  status?: 'ongoing' | 'proposed' | 'completed';
  date?: Date;
}

interface Props {
  slides?: Slide[];
  mainTitle: string;
  mainSubtitle: string;
}

const {
  slides = [],
  mainTitle,
  mainSubtitle,
} = Astro.props;

// Dynamically import all hero images from the assets folder
const heroImagesRaw = import.meta.glob('../assets/hero/*.jpg', { eager: true });

// Extract the image imports and sort by filename for consistent order
const heroImagesList = Object.entries(heroImagesRaw)
  .sort(([pathA], [pathB]) => pathA.localeCompare(pathB))
  .map(([, mod]: [string, any]) => mod.default);

// Optimize all images at build time (convert to WebP, compress)
const heroBackgrounds = await Promise.all(
  heroImagesList.map(async (img) => {
    const optimized = await getImage({
      src: img,
      format: 'webp',
      quality: 80,
      width: 1920,
    });
    return optimized.src;
  })
);

const contentTypeColors = {
  topic: 'bg-blue-500',
  publication: 'bg-purple-500',
  thesis: 'bg-green-500',
};

const statusColors = {
  ongoing: 'bg-yellow-500',
  proposed: 'bg-gray-500',
  completed: 'bg-hs-gray-500',
};
---

<section class="relative h-[400px] md:h-[500px] bg-hs-gray-900 overflow-hidden">
  {slides.length > 0 ? (
    <>
      <!-- Slideshow Container -->
      <div id="slideshow" class="absolute inset-0">
        {slides.map((slide, index) => {
          // Cycle through background images (use modulo to loop if more slides than images)
          const bgImage = heroBackgrounds[index % heroBackgrounds.length];
          return (
            <div
              class:list={[
                'slide absolute inset-0 transition-opacity duration-1000',
                index === 0 ? 'opacity-100' : 'opacity-0',
              ]}
              data-index={index}
              style={`background-image: url('${bgImage}'); background-size: cover; background-position: center;`}
            >
              <!-- Dark overlay for better text readability -->
              <div class="absolute inset-0 bg-gradient-to-br from-black/65 via-black/55 to-black/75"></div>
            </div>
          );
        })}
      </div>

      <!-- Main title - Fixed position at top -->
      <div class="absolute top-0 left-0 right-0 pt-12 md:pt-16 text-center px-4">
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-2">
          {mainTitle}
        </h1>
        <p class="text-base md:text-lg text-white/80">
          {mainSubtitle}
        </p>
      </div>

      <!-- Project slides content - Centered independently -->
      <div class="absolute inset-0 flex items-center justify-center px-4 pt-32 md:pt-40">
        <div class="max-w-3xl w-full text-center">
          {slides.map((slide, index) => (
            <div
              class:list={[
                'project-slide-content transition-opacity duration-1000',
                index === 0 ? 'opacity-100 block' : 'opacity-0 hidden',
              ]}
              data-index={index}
            >
              <div class="flex items-center justify-center gap-2 mb-3">
                <span class={`text-xs px-2 py-1 rounded-full text-white ${contentTypeColors[slide.contentType]}`}>
                  {slide.contentType === 'topic' ? 'Research Topic' : slide.contentType.charAt(0).toUpperCase() + slide.contentType.slice(1)}
                </span>
                {slide.status && (
                  <span class={`text-xs px-2 py-1 rounded-full text-white ${statusColors[slide.status]}`}>
                    {slide.status}
                  </span>
                )}
              </div>
              <a href={slide.href} class="block mb-3 hover:opacity-90 transition-opacity">
                <h2 class="text-xl md:text-2xl font-medium text-white">
                {slide.title}
                </h2>
              </a>
              <p class="text-sm md:text-base text-white/90 mb-4">
                {slide.description}
              </p>
              <a
                href={slide.href}
                class="inline-block bg-hs-cyan text-white px-6 py-2 rounded-md font-medium hover:bg-opacity-90 transition-colors"
              >
                Learn More &rarr;
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation Arrows -->
      {slides.length > 1 && (
        <>
          <button
            class="slide-prev absolute left-4 top-1/2 -translate-y-1/2 z-10 bg-white/20 hover:bg-white/40 text-white p-3 rounded-full transition-colors"
            aria-label="Previous slide"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>
          <button
            class="slide-next absolute right-4 top-1/2 -translate-y-1/2 z-10 bg-white/20 hover:bg-white/40 text-white p-3 rounded-full transition-colors"
            aria-label="Next slide"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </>
      )}

      <!-- Navigation Dots -->
      {slides.length > 1 && (
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-2">
          {slides.map((_, index) => (
            <button
              class:list={[
                'slide-dot w-3 h-3 rounded-full transition-colors',
                index === 0 ? 'bg-white' : 'bg-white/50 hover:bg-white/75',
              ]}
              data-index={index}
              aria-label={`Go to slide ${index + 1}`}
            />
          ))}
        </div>
      )}
    </>
  ) : (
    <>
      <!-- Fallback when no projects - show first hero image -->
      <div
        class="absolute inset-0"
        style={`background-image: url('${heroBackgrounds[0]}'); background-size: cover; background-position: center;`}
      >
        <div class="absolute inset-0 bg-gradient-to-br from-black/60 via-black/50 to-black/70"></div>
      </div>

      <!-- Main title - Fixed position at top -->
      <div class="absolute top-0 left-0 right-0 pt-12 md:pt-16 text-center px-4">
        <h1 class="text-3xl md:text-5xl font-bold text-white mb-2">
          {mainTitle}
        </h1>
        <p class="text-lg md:text-xl text-white/90 max-w-2xl mx-auto">
          {mainSubtitle}
        </p>
      </div>
    </>
  )}
</section>

<script>
  const slideContainers = document.querySelectorAll('.slide');
  const slideContents = document.querySelectorAll('.project-slide-content');
  const dots = document.querySelectorAll('.slide-dot');
  let currentIndex = 0;
  let intervalId: ReturnType<typeof setInterval>;

  function showSlide(index: number) {
    slideContainers.forEach((slide, i) => {
      slide.classList.toggle('opacity-100', i === index);
      slide.classList.toggle('opacity-0', i !== index);
    });
    slideContents.forEach((content, i) => {
      content.classList.toggle('opacity-100', i === index);
      content.classList.toggle('opacity-0', i !== index);
      content.classList.toggle('block', i === index);
      content.classList.toggle('hidden', i !== index);
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === index);
      dot.classList.toggle('bg-white/50', i !== index);
    });
    currentIndex = index;
  }

  function nextSlide() {
    showSlide((currentIndex + 1) % slideContainers.length);
  }

  function prevSlide() {
    showSlide((currentIndex - 1 + slideContainers.length) % slideContainers.length);
  }

  // Auto-advance slides
  function startAutoPlay() {
    intervalId = setInterval(nextSlide, 6000);
  }

  function stopAutoPlay() {
    clearInterval(intervalId);
  }

  // Click handlers for arrow buttons
  const prevBtn = document.querySelector('.slide-prev');
  const nextBtn = document.querySelector('.slide-next');

  prevBtn?.addEventListener('click', () => {
    prevSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  nextBtn?.addEventListener('click', () => {
    nextSlide();
    stopAutoPlay();
    startAutoPlay();
  });

  // Click handlers for dots
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index') || '0');
      showSlide(index);
      stopAutoPlay();
      startAutoPlay();
    });
  });

  // Start auto-play
  if (slideContainers.length > 1) {
    startAutoPlay();
  }
</script>
