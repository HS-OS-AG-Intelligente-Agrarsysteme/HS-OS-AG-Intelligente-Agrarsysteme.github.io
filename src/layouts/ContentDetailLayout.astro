---
import Layout from "./Layout.astro";

interface Props {
  contentType: "topic" | "publication" | "thesis";
  title: string;
  description: string;
  metadata: Record<string, any>;
}

const { contentType, title, description, metadata } = Astro.props;

const contentTypeLabels = {
  topic: "Research Topic",
  publication: "Publication",
  thesis: "Thesis",
};

const thesisTypeLabels = {
  bachelor: "Bachelor Thesis",
  master: "Master Thesis",
  phd: "Dissertation",
};

const contentTypeColors = {
  topic: "bg-blue-100 text-blue-800",
  publication: "bg-purple-100 text-purple-800",
  thesis: "bg-green-100 text-green-800",
};

const formatDate = (date: Date | undefined) => {
  if (!date) return null;
  return date.toLocaleDateString("en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<Layout title={title} description={description}>
  <article class="section">
    <div class="container-narrow">
      <!-- Back link -->
      <a
        href={contentType === "topic"
          ? "/topics"
          : contentType === "publication"
            ? "/publications"
            : "/theses"}
        class="text-sm text-hs-cyan hover:underline mb-6 inline-block"
      >
        &larr; Back to {
          contentType === "topic"
            ? "Research Topics"
            : contentType === "publication"
              ? "Publications"
              : "Theses"
        }
      </a>

      <!-- Header -->
      <header class="mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span
            class={`text-sm px-3 py-1 rounded-full ${contentTypeColors[contentType]}`}
          >
            {contentTypeLabels[contentType]}
          </span>
        </div>

        <h1 class="text-3xl md:text-4xl font-bold text-hs-gray-900 mb-4">
          {title}
        </h1>

        <p class="text-lg text-hs-gray-700">
          {description}
        </p>

        <!-- Content-type specific metadata -->
        <div class="mt-6 py-4 border-t border-b border-hs-gray-300">
          {
            contentType === "topic" && (
              <div class="space-y-2 text-sm">
                <p>
                  <span class="font-medium text-hs-gray-900">Author:</span>
                  <span class="text-hs-gray-700 ml-2">{metadata.author}</span>
                </p>
                <p>
                  <span class="font-medium text-hs-gray-900">Published:</span>
                  <span class="text-hs-gray-700 ml-2">
                    {formatDate(metadata.date)}
                  </span>
                </p>
              </div>
            )
          }

          {
            contentType === "publication" && (
              <div class="space-y-2 text-sm">
                <p>
                  <span class="font-medium text-hs-gray-900">Authors:</span>
                  <span class="text-hs-gray-700 ml-2">
                    {metadata.authors?.join(", ")}
                  </span>
                </p>
                <p>
                  <span class="font-medium text-hs-gray-900">Published:</span>
                  <span class="text-hs-gray-700 ml-2">
                    {metadata.date
                      .toLocaleDateString("en-GB", {
                        day: "2-digit",
                        month: "short",
                        year: "numeric",
                      })
                      .replace(",", "")}
                  </span>
                </p>
              </div>
            )
          }

          {
            contentType === "thesis" && (
              <div class="space-y-2 text-sm">
                <p>
                  <span class="font-medium text-hs-gray-900">Author:</span>
                  <span class="text-hs-gray-700 ml-2">{metadata.author}</span>
                </p>
                {metadata.supervisor && (
                  <p>
                    <span class="font-medium text-hs-gray-900">
                      Supervisor:
                    </span>
                    <span class="text-hs-gray-700 ml-2">
                      {metadata.supervisor}
                    </span>
                  </p>
                )}
                <p>
                  <span class="font-medium text-hs-gray-900">Type:</span>
                  <span class="text-hs-gray-700 ml-2">
                    {thesisTypeLabels[metadata.type as keyof typeof thesisTypeLabels]}
                  </span>
                </p>
                {metadata.proposal && (
                  <p>
                    <span class="font-medium text-hs-gray-900">Status:</span>
                    <span class="text-hs-gray-700 ml-2">Proposal</span>
                  </p>
                )}
                {metadata.startDate && (
                  <p>
                    <span class="font-medium text-hs-gray-900">Period:</span>
                    <span class="text-hs-gray-700 ml-2">
                      {metadata.startDate
                        .toLocaleDateString("en-GB", {
                          day: "2-digit",
                          month: "short",
                          year: "numeric",
                        })
                        .replace(",", "")}
                      {metadata.endDate &&
                        ` – ${metadata.endDate.toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" }).replace(",", "")}`}
                    </span>
                  </p>
                )}
              </div>
            )
          }
        </div>
      </header>

      <!-- Links -->
      {
        (metadata.externalUrl ||
          metadata.codeUrl ||
          metadata.pdfUrl ||
          metadata.doi) && (
          <div class="flex flex-wrap gap-4 mb-8">
            {metadata.externalUrl && (
              <a
                href={metadata.externalUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                Website &rarr;
              </a>
            )}
            {metadata.codeUrl && (
              <a
                href={metadata.codeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-hs-gray-900 text-white px-6 py-2 rounded-md font-medium hover:bg-hs-gray-700 transition-colors"
              >
                View Code
              </a>
            )}
            {metadata.pdfUrl && (
              <a
                href={metadata.pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-hs-gray-900 text-white px-6 py-2 rounded-md font-medium hover:bg-hs-gray-700 transition-colors"
              >
                Download PDF
              </a>
            )}
            {metadata.doi && (
              <a
                href={`https://doi.org/${metadata.doi}`}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-hs-gray-900 text-white px-6 py-2 rounded-md font-medium hover:bg-hs-gray-700 transition-colors"
              >
                DOI
              </a>
            )}
          </div>
        )
      }

      <!-- Content with LaTeX support via KaTeX -->
      <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      />
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  .prose {
    @apply text-hs-gray-700;
  }
  .prose h2 {
    @apply text-2xl font-medium text-hs-gray-900 mt-8 mb-4;
  }
  .prose h3 {
    @apply text-xl font-medium text-hs-gray-900 mt-6 mb-3;
  }
  .prose p {
    @apply mb-4;
  }
  .prose ul {
    @apply list-disc mb-4 pl-6;
  }
  .prose ol {
    @apply list-decimal mb-4 pl-6;
  }
  .prose li {
    @apply mb-2;
  }
  .prose a {
    @apply text-hs-cyan hover:underline;
  }
  .prose img {
    @apply rounded-lg my-6;
  }
  .prose blockquote {
    @apply border-l-4 border-hs-cyan pl-4 italic text-hs-gray-500;
  }
  .prose code {
    @apply bg-hs-gray-100 px-1.5 py-0.5 rounded text-sm;
  }
  .prose pre {
    @apply bg-hs-gray-900 text-white p-4 rounded-lg overflow-x-auto;
  }
  .prose pre code {
    @apply bg-transparent p-0;
  }

  /* KaTeX styles */
  .katex {
    @apply text-hs-gray-900;
  }
  .katex-display {
    @apply my-4;
  }
</style>
